/* pages/registration/registration.wxss */
@import "../../../global-colors.wxss";
#pi-day-container {
  padding: 0 16px;
  padding-top: 10px;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  box-sizing: border-box;
}

#pi-day-top-container {
  display: flex;
  justify-content: space-between;
}

#pi-day-top-right-container {
  display: flex;
}

#pi-day-top-scan-button-container {
  width: 41px;
  height: 41px;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--button-background-color);
  border-radius: 50%;
  margin-left: 10px;
}

#pi-day-top-scan-button-image {
  width: 100%;
  height: 100%;
}

@media (prefers-color-scheme: dark) {
    #pi-day-top-scan-button-image {
        filter: invert();
    }
}

#pi-day-info-container {
  display: flex;
  flex-direction: column;
}

#pi-day-big-title {
  padding-bottom: 10px;
}
#pi-day-big-title-sub {
  padding-bottom: 20px;
}

.question {
  width: 100%;
  margin-bottom: 20px;
  display: flex;
  flex-direction: column;
}

.question-label {
  font-size: 14px;
  font-weight: 700;
  margin-bottom: 9px;
}

.question-input {
  background-color: var(--subcontainer-background);
  border-radius: 9px;
  padding: 0 13px;
  font-size: 17px;
  padding: 12px;
}

.question-input-with-selector {
  background-color: var(--subcontainer-background);
  border-radius: 9px;
  padding: 0 13px;
  font-size: 17px;
  padding: 12px;
  margin-bottom: 10px;
}

.question-disabled-text{
  color: var(--secondary);
}

.question-select {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.selectorIcon{
  width: 20px;
  height: 20px;
}

#button-container {
  margin-bottom: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

#submit-button {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 11px;
  background-color: #D2E3FA;
  width: 138px;
  height: 48px;
}

#submit-button-text {
  color: var(--link);
  font-size: 22px;
  font-weight: 500;
}